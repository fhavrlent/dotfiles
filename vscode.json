{
  "telemetry.enableTelemetry": false,
  "telemetry.enableCrashReporter": false,
  "editor.formatOnSave": true,
  "prettier.singleQuote": true,
  "workbench.iconTheme": "vscode-icons",
  "workbench.colorTheme": "Monokai Dimmed",
  "editor.tabSize": 2,
  "clock.dateFormat": "HH:MM",
  "files.associations": {
    "*.js": "javascriptreact"
  },
  "editor.tabCompletion": "on",
  "editor.snippetSuggestions": "top",
  "git.autofetch": true,
  "files.useExperimentalFileWatcher": true,
  "editor.fontLigatures": true,
  "editor.fontFamily": "Fira Code",
  "vsicons.dontShowNewVersionMessage": true,
  "gitlens.advanced.messages": {
    "suppressCommitHasNoPreviousCommitWarning": false,
    "suppressCommitNotFoundWarning": false,
    "suppressFileNotUnderSourceControlWarning": false,
    "suppressGitVersionWarning": false,
    "suppressLineUncommittedWarning": false,
    "suppressNoRepositoryWarning": false,
    "suppressResultsExplorerNotice": true,
    "suppressShowKeyBindingsNotice": true,
    "suppressUpdateNotice": false,
    "suppressWelcomeNotice": true
  },
  "gitlens.keymap": "chorded",
  "prettier.disableLanguages": ["vue", "markdown"],
  "javascript.updateImportsOnFileMove.enabled": "always",
  "editor.fontSize": 14,
  "window.zoomLevel": 0,
  "diffEditor.ignoreTrimWhitespace": false,
  "prettier.trailingComma": "all",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "yaml.schemas": {
    "file:///Users/fhavrlent/.vscode/extensions/atlassian.atlascode-2.4.9/resources/schemas/pipelines-schema.json": "bitbucket-pipelines.yml"
  },
  "atlascode.jira.jqlList": [
    {
      "id": "cf70649d-732d-44a0-bc1d-a752e343673b",
      "enabled": true,
      "name": "My jira.ableneo.com Issues",
      "query": "assignee = currentUser() AND resolution = Unresolved ORDER BY lastViewed DESC",
      "siteId": "jira.ableneo.com",
      "monitor": true
    }
  ],
  "atlascode.jira.lastCreateSiteAndProject": {
    "siteId": "jira.ableneo.com",
    "projectKey": "RESIDE"
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "todo-tree.tree.showScanModeButton": false,
  "gauge.recommendedSettings.options": "Apply & Reload",
  "[gauge]": {
    
  },
  "eslint.alwaysShowStatus": true,
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "atlascode.configurationTarget": "user"
}
